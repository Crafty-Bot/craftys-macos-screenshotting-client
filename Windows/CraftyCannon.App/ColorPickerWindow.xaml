<Window x:Class="CraftyCannon.App.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Picker"
        Width="520"
        Height="320"
        MinWidth="480"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Color" FontSize="18" FontWeight="SemiBold" Foreground="#151922" />
            <DockPanel Margin="0,8,0,0">
                <Button x:Name="PaletteButton" Content="Palette" Width="72" Height="30" Click="PaletteButton_Click" />
                <Border x:Name="ColorSwatch"
                        Width="56"
                        Height="28"
                        Margin="10,0,0,0"
                        BorderBrush="#2E3440"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Button Content="Pick From Screen" Height="30" MinWidth="140" Margin="10,0,0,0" Click="PickFromScreenButton_Click" />
            </DockPanel>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#D7DCE2" BorderThickness="0,1,0,0" Margin="0,0,0,14" />

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="HEX (RGB)" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#20242B" />
            <TextBox x:Name="HexRgbBox" Grid.Column="1" Height="28" FontFamily="Consolas" FontSize="12" IsReadOnly="True" IsEnabled="False" />
            <Button Grid.Column="2" Content="Copy" Height="26" Margin="8,0,0,0" Click="CopyHexRgb_Click" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="HEX (RGBA)" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#20242B" />
            <TextBox x:Name="HexRgbaBox" Grid.Column="1" Height="28" FontFamily="Consolas" FontSize="12" IsReadOnly="True" IsEnabled="False" />
            <Button Grid.Column="2" Content="Copy" Height="26" Margin="8,0,0,0" Click="CopyHexRgba_Click" />
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="RGBA" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#20242B" />
            <TextBox x:Name="RgbaBox" Grid.Column="1" Height="28" FontFamily="Consolas" FontSize="12" IsReadOnly="True" IsEnabled="False" />
            <Button Grid.Column="2" Content="Copy" Height="26" Margin="8,0,0,0" Click="CopyRgba_Click" />
        </Grid>

        <DockPanel Grid.Row="6">
            <TextBlock x:Name="SourceText" FontSize="12" Foreground="#5C6675" />
            <TextBlock x:Name="CopyStatusText" FontSize="12" Foreground="#5C6675" HorizontalAlignment="Right" />
        </DockPanel>
    </Grid>
</Window>