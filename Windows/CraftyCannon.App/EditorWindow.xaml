<Window x:Class="CraftyCannon.App.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CraftyCannon Editor"
        Width="1100"
        Height="760"
        MinWidth="820"
        MinHeight="560"
        Background="#F5F7FA"
        KeyDown="Window_KeyDown">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="#D7DCE2" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ComboBox x:Name="ToolPicker" Width="170" Height="32" Margin="0,0,8,0" SelectionChanged="ToolPicker_SelectionChanged" />
                    <Button x:Name="UndoButton" Content="Undo" Height="32" MinWidth="70" Margin="0,0,6,0" Click="Undo_Click" IsEnabled="False" />
                    <Button x:Name="RedoButton" Content="Redo" Height="32" MinWidth="70" Margin="0,0,12,0" Click="Redo_Click" IsEnabled="False" />
                    <Button Content="Resize" Height="32" MinWidth="72" Margin="0,0,6,0" Click="Resize_Click" />
                    <Button Content="Rotate L" Height="32" MinWidth="76" Margin="0,0,6,0" Click="RotateLeft_Click" />
                    <Button Content="Rotate R" Height="32" MinWidth="76" Margin="0,0,6,0" Click="RotateRight_Click" />
                    <Button Content="Flip H" Height="32" MinWidth="64" Margin="0,0,6,0" Click="FlipHorizontal_Click" />
                    <Button Content="Flip V" Height="32" MinWidth="64" Margin="0,0,6,0" Click="FlipVertical_Click" />
                    <Button x:Name="DetectSensitiveButton" Content="Detect Sensitive" Height="32" MinWidth="120" Margin="0,0,12,0" Click="DetectSensitive_Click" />
                    <Slider x:Name="ZoomSlider" Width="110" Minimum="25" Maximum="400" Value="100" TickFrequency="25" IsSnapToTickEnabled="True" ValueChanged="ZoomSlider_ValueChanged" />
                    <TextBlock x:Name="ZoomText" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#394150" />
                </StackPanel>
                <Button x:Name="SaveUploadButton" DockPanel.Dock="Right" Content="Save &amp; Upload" Height="32" MinWidth="120" Click="SaveAndUpload_Click" />
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#E8EBEF" Padding="18">
                <ScrollViewer x:Name="EditorScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Background="#FFFFFF" BorderBrush="#C8CED6" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid x:Name="EditorSurface" Background="Transparent" MouseDown="EditorSurface_MouseDown" MouseMove="EditorSurface_MouseMove" MouseUp="EditorSurface_MouseUp" MouseLeave="EditorSurface_MouseLeave">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                            </Grid.LayoutTransform>
                            <Image x:Name="ImagePreview" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality" />
                            <Image x:Name="InkLayerImage" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality" IsHitTestVisible="False" />
                            <Canvas x:Name="OverlayCanvas" Background="Transparent" IsHitTestVisible="False" />
                            <Canvas x:Name="InkCanvas" Background="Transparent" IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D7DCE2" BorderThickness="1,0,0,0" Padding="14">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Style" FontSize="16" FontWeight="SemiBold" Foreground="#20242B" Margin="0,0,0,10" />
                        <TextBlock Text="Color" FontSize="12" Foreground="#596273" Margin="0,0,0,2" />
                        <ComboBox x:Name="InkColorBox" Height="30" Margin="0,0,0,8" SelectionChanged="InkColorBox_SelectionChanged">
                            <ComboBoxItem Content="Red" Tag="Red" IsSelected="True" />
                            <ComboBoxItem Content="Yellow" Tag="Yellow" />
                            <ComboBoxItem Content="Blue" Tag="DodgerBlue" />
                            <ComboBoxItem Content="Green" Tag="LimeGreen" />
                            <ComboBoxItem Content="Black" Tag="Black" />
                            <ComboBoxItem Content="White" Tag="White" />
                        </ComboBox>
                        <TextBlock x:Name="StrokeWidthText" FontSize="12" Foreground="#596273" Margin="0,0,0,2" />
                        <Slider x:Name="StrokeWidthSlider" Minimum="1" Maximum="30" Value="6" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="StrokeWidthSlider_ValueChanged" Margin="0,0,0,8" />
                        <TextBlock x:Name="FontSizeText" FontSize="12" Foreground="#596273" Margin="0,0,0,2" />
                        <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="72" Value="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="FontSizeSlider_ValueChanged" Margin="0,0,0,8" />
                        <TextBlock x:Name="FilterStrengthText" FontSize="12" Foreground="#596273" Margin="0,0,0,2" />
                        <Slider x:Name="FilterStrengthSlider" Minimum="2" Maximum="60" Value="14" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="FilterStrengthSlider_ValueChanged" Margin="0,0,0,10" />
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="Reset Steps" Height="30" Margin="0,0,4,0" Click="ResetSteps_Click" />
                            <Button Content="Set Sticker" Height="30" Margin="4,0,0,0" Click="SetSticker_Click" />
                        </UniformGrid>
                        <TextBlock Text="Tools" FontSize="16" FontWeight="SemiBold" Foreground="#20242B" Margin="0,0,0,10" />
                    </StackPanel>
                    <ListBox x:Name="ToolList" BorderBrush="#D7DCE2" SelectionChanged="ToolList_SelectionChanged" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>

