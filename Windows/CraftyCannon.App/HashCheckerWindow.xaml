<Window x:Class="CraftyCannon.App.HashCheckerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hash Checker"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F4F5F7" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Hash Checker" FontSize="18" FontWeight="SemiBold" Foreground="#20242B" />
            <TextBlock Text="Compute common hashes for a file or text input." FontSize="13" Foreground="#596273" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Height="1" Background="#D7DCE2" Margin="0,0,0,12" />

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Choose File..." Height="32" MinWidth="110" Margin="0,0,8,0" Click="ChooseFile_Click" />
            <Button x:Name="ClearFileButton" Grid.Column="1" Content="Clear File" Height="32" MinWidth="88" Margin="0,0,8,0" Click="ClearFile_Click" IsEnabled="False" />
            <TextBlock x:Name="FilePathText" Grid.Column="2" VerticalAlignment="Center" FontFamily="Consolas" FontSize="11" Foreground="#596273" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="36" />
            <ProgressBar x:Name="ComputingProgress" Grid.Column="3" Width="90" Height="10" VerticalAlignment="Center" IsIndeterminate="True" Visibility="Collapsed" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Or hash this text" FontSize="12" FontWeight="SemiBold" Foreground="#20242B" Margin="0,0,0,6" />
            <TextBox x:Name="InputTextBox" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" TextChanged="InputTextBox_TextChanged" />
        </Grid>

        <Border Grid.Row="4" Height="1" Background="#D7DCE2" Margin="0,0,0,12" />

        <Grid Grid.Row="5" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="76" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="MD5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,8" />
            <TextBox x:Name="Md5Box" Grid.Row="0" Grid.Column="1" Height="30" FontFamily="Consolas" FontSize="11" IsReadOnly="True" Margin="0,0,8,8" />
            <Button x:Name="CopyMd5Button" Grid.Row="0" Grid.Column="2" Content="Copy" Height="28" Click="CopyMd5_Click" IsEnabled="False" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="SHA-1" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,8" />
            <TextBox x:Name="Sha1Box" Grid.Row="1" Grid.Column="1" Height="30" FontFamily="Consolas" FontSize="11" IsReadOnly="True" Margin="0,0,8,8" />
            <Button x:Name="CopySha1Button" Grid.Row="1" Grid.Column="2" Content="Copy" Height="28" Click="CopySha1_Click" IsEnabled="False" Margin="0,0,0,8" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA-256" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox x:Name="Sha256Box" Grid.Row="2" Grid.Column="1" Height="30" FontFamily="Consolas" FontSize="11" IsReadOnly="True" Margin="0,0,8,0" />
            <Button x:Name="CopySha256Button" Grid.Row="2" Grid.Column="2" Content="Copy" Height="28" Click="CopySha256_Click" IsEnabled="False" />
        </Grid>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Expected hash (optional)" FontSize="12" FontWeight="SemiBold" Foreground="#20242B" Margin="0,0,0,6" />
            <TextBox x:Name="ExpectedHashBox" Height="30" VerticalContentAlignment="Center" TextChanged="ExpectedHashBox_TextChanged" ToolTip="Paste expected hash to compare" />
            <TextBlock x:Name="ExpectedMatchText" FontSize="12" Margin="0,6,0,0" />
            <TextBlock x:Name="ErrorText" Foreground="#A12626" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0" />
            <TextBlock x:Name="CopyStatusText" Foreground="#596273" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</Window>