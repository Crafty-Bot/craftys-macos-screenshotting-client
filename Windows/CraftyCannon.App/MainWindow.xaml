<Window x:Class="CraftyCannon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CraftyCannon" Height="760" Width="1180" MinHeight="620" MinWidth="980">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Background="{DynamicResource CraftyWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CraftyRailBackgroundBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="CraftyCannon"
                           Foreground="{DynamicResource CraftyRailTextBrush}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="18,20,18,14" />
                <ListBox ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         DisplayMemberPath="Name"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource CraftyRailTextBrush}"
                         Margin="10,0,10,16" />
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource CraftyPanelBackgroundBrush}" BorderBrush="{DynamicResource CraftyBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBox DockPanel.Dock="Top"
                         Margin="16"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem}"
                         BorderThickness="0"
                         Margin="8,0,8,16" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding SelectedSection.Name}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource CraftyPrimaryTextBrush}" />
                <TextBlock Text="{Binding SelectedItem}"
                           FontSize="15"
                           Foreground="{DynamicResource CraftySecondaryTextBrush}"
                           Margin="0,6,0,18" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Border x:Name="ScaffoldPanel"
                        Background="{DynamicResource CraftyPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource CraftyBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="22">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistorySelected}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="Windows port scaffold"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CraftyPrimaryTextBrush}" />
                        <TextBlock Text="{Binding DetailText}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,14"
                                   Foreground="{DynamicResource CraftyPrimaryTextBrush}" />
                        <Border Background="{DynamicResource CraftyPanelMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource CraftyBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,0,0,20">
                            <TextBlock Text="{Binding StatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource CraftyPrimaryTextBrush}" />
                        </Border>
                        <WrapPanel>
                            <Button Content="Capture Region" Height="36" MinWidth="130" Margin="0,0,8,8" Click="CaptureRegion_Click" />
                            <Button Content="Capture Region (Expiring Link)" Height="36" MinWidth="220" Margin="0,0,8,8" Click="CaptureRegionExpiring_Click" />
                            <Button Content="Capture Frozen Region" Height="36" MinWidth="170" Margin="0,0,8,8" Click="CaptureFrozenRegion_Click" />
                            <Button Content="Capture Window" Height="36" MinWidth="130" Margin="0,0,8,8" Click="CaptureWindow_Click" />
                            <Button Content="Capture Top Taskbar" Height="36" MinWidth="160" Margin="0,0,8,8" Click="CaptureTopTaskbar_Click" />
                            <Button Content="Capture Full Screen" Height="36" MinWidth="150" Margin="0,0,8,8" Click="CaptureFullScreen_Click" />
                            <Button Content="Record Screen (30s max)" Height="36" MinWidth="180" Margin="0,0,8,8" Click="CaptureScreenRecording_Click" />
                            <Button Content="Upload Clipboard" Height="36" MinWidth="130" Margin="0,0,8,8" Click="UploadClipboard_Click" />
                            <Button Content="Upload File" Height="36" MinWidth="110" Margin="0,0,8,8" Click="UploadFile_Click" />
                            <Button Content="Upload File (Expiring Link)..." Height="36" MinWidth="190" Margin="0,0,8,8" Click="UploadExpiringFile_Click" />
                            <Button Content="Upload URL" Height="36" MinWidth="110" Margin="0,0,8,8" Click="UploadUrl_Click" />
                            <Button Content="Shorten URL" Height="36" MinWidth="110" Margin="0,0,8,8" Click="ShortenUrl_Click" />
                            <Button Content="Upload Text" Height="36" MinWidth="110" Margin="0,0,8,8" Click="UploadText_Click" />
                            <Button Content="Upload Folder" Height="36" MinWidth="120" Margin="0,0,8,8" Click="UploadFolder_Click" />
                            <Button Content="Watch Folders" Height="36" MinWidth="130" Margin="0,0,8,8" Click="WatchFolders_Click" />
                            <Button Content="Index Folder" Height="36" MinWidth="110" Margin="0,0,8,8" Click="IndexFolder_Click" />
                            <Button Content="Color Picker" Height="36" MinWidth="120" Margin="0,0,8,8" Click="ColorPicker_Click" />
                            <Button Content="QR Code" Height="36" MinWidth="100" Margin="0,0,8,8" Click="QrCode_Click" />
                            <Button Content="Hash Checker" Height="36" MinWidth="120" Margin="0,0,8,8" Click="HashChecker_Click" />
                            <Button Content="Directory Indexer" Height="36" MinWidth="140" Margin="0,0,8,8" Click="DirectoryIndexer_Click" />
                            <Button Content="Pin Clipboard Image" Height="36" MinWidth="160" Margin="0,0,8,8" Click="PinClipboardImage_Click" />
                            <Button Content="Pin Image File" Height="36" MinWidth="130" Margin="0,0,8,8" Click="PinImageFile_Click" />
                            <Button Content="Open Latest Image in Editor" Height="36" MinWidth="190" Margin="0,0,8,8" Click="OpenLatestEditor_Click" />
                            <Button Content="Preferences" Height="36" MinWidth="110" Margin="0,0,8,8" Click="Preferences_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid x:Name="HistoryPanel" Visibility="{Binding IsHistorySelected, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="430" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" MinWidth="330" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CraftyPanelBackgroundBrush}" BorderBrush="{DynamicResource CraftyBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Height="32"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Filter by filename, URL, profile, status, or OCR text"
                                             Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="1"
                                              Margin="8,0,0,0"
                                              Height="32"
                                              ItemsSource="{Binding HistoryStatusFilters}"
                                              SelectedItem="{Binding HistoryStatusFilter}" />
                                </Grid>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding FilteredHistoryRows}"
                                      SelectedItem="{Binding SelectedHistoryRow}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Filename" Binding="{Binding FileName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                    <DataGridTextColumn Header="Progress" Binding="{Binding Progress}" Width="72" />
                                    <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="64" />
                                    <DataGridTextColumn Header="Elapsed" Binding="{Binding Elapsed}" Width="64" />
                                    <DataGridTextColumn Header="Remaining" Binding="{Binding Remaining}" Width="82" />
                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource CraftyPanelBackgroundBrush}" BorderBrush="{DynamicResource CraftyBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" Background="{DynamicResource CraftyPanelMutedBackgroundBrush}" BorderBrush="{DynamicResource CraftyBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="{DynamicResource CraftyPrimaryTextBrush}" />
                            </Border>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedHistoryRow.FileName, TargetNullValue=No selection}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource CraftyPrimaryTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SelectedHistoryRow.Status}"
                                           Foreground="{DynamicResource CraftySecondaryTextBrush}"
                                           Margin="0,4,0,12" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Created" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedHistoryRow.CreatedAt}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Profile" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedHistoryRow.Profile}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Source" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedHistoryRow.Source}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="URL" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedHistoryRow.Url}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Local file" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedHistoryRow.LocalFile}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Expiry" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedHistoryRow.Expiry}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Mirror" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedHistoryRow.Secondary}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="OCR" Foreground="{DynamicResource CraftySecondaryTextBrush}" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedHistoryRow.Ocr}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                </Grid>

                                <TextBlock Text="{Binding SelectedHistoryRow.Error}" Foreground="#A12626" TextWrapping="Wrap" Margin="0,0,0,12" />

                                <WrapPanel>
                                    <Button Content="Copy" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanCopySelectedHistoryUrl}" Click="HistoryCopy_Click" />
                                    <Button Content="Open" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanOpenSelectedHistoryUrl}" Click="HistoryOpen_Click" />
                                    <Button Content="Reveal" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanRevealSelectedHistoryFile}" Click="HistoryReveal_Click" />
                                    <Button Content="Delete" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanDeleteSelectedManagedCopy}" Click="HistoryDelete_Click" />
                                    <Button Content="Shorten" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanShortenSelectedHistoryUrl}" Click="HistoryShorten_Click" />
                                    <Button Content="Reupload" Height="32" MinWidth="82" Margin="0,0,8,8" IsEnabled="{Binding CanReuploadSelectedHistoryFile}" Click="HistoryReupload_Click" />
                                    <Button Content="Edit" Height="32" MinWidth="76" Margin="0,0,8,8" IsEnabled="{Binding CanEditSelectedHistoryImage}" Click="HistoryEdit_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>







