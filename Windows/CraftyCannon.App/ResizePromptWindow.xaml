<Window x:Class="CraftyCannon.App.ResizePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize" Height="250" Width="420" MinHeight="230" MinWidth="380"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F4F5F7" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Enter new pixel dimensions." TextWrapping="Wrap" Foreground="#20242B" Margin="0,0,0,14" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Width" Margin="0,0,0,4" />
                <TextBox x:Name="WidthBox" Height="30" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Height" Margin="0,0,0,4" />
                <TextBox x:Name="HeightBox" Height="30" />
            </StackPanel>
        </Grid>
        <CheckBox x:Name="LockAspectBox" Grid.Row="2" Content="Lock aspect ratio" IsChecked="True" Margin="0,12,0,0" />
        <TextBlock x:Name="ValidationText" Grid.Row="3" Foreground="#A12626" TextWrapping="Wrap" Margin="0,12,0,0" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,44,0,0">
            <Button Content="Cancel" Width="92" Height="32" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Resize" Width="92" Height="32" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>